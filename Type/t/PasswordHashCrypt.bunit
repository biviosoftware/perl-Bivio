Type();
my($pass) = 'abcdef';
my($salt) = 'kz';
my($hash) = 'ltIzEfODKJg';
my($literal) = $salt . $hash;
[
    [] => [
        ID => 'crypt',
        REGEX => qr/^.{13}$/,
        SALT_LENGTH => 2,
        {
            method => 'from_literal',
            compute_return => sub {
                my(undef, $actual) = @_;
                return [
                    ref($actual->[0]) ? $actual->[0]->as_literal : $actual->[0],
                    $actual->[1],
                ];
            },
        } => [
            'too-short' => [undef, b_use('Bivio.TypeError')->SYNTAX_ERROR],
            $literal => [$literal, undef],
        ],
        to_literal => [
            [$pass, $salt] => $literal,
        ],
    ],
    sub {class()->from_literal($literal)} => [
        as_literal => $literal,
        get_id => 'crypt',
        get_salt => $salt,
        get_hash => $hash,
        is_equal => [
            $pass => 1,
            ghijkl => 0,
        ],
    ],
];
